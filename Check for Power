Check for Power


class Solution {
  public:
    bool isPower(int x, int y) {
        // code here
        if(x==1) return false;
        if(y==1) return true;
        while(y>1)
        {
            if(y%x!=0) return false;
            y = y/x;
            // cout<<"y is"<<y<<endl;
            
            
        }
        return true;
    }
};
