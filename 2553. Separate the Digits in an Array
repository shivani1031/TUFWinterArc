2553. Separate the Digits in an Array



class Solution {
public:
    vector<int> separateDigits(vector<int>& nums) {
        vector<int> ans;
        for(int num:nums)
        {
            string f = to_string(num);
            for(char ch:f)
            {
                ans.push_back(ch-'0');
            }
        }
        return ans;
    }
};
